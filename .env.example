# ============================================================
# Chokepoint Research Agent — environment variables
# cp .env.example .env  then fill keys
# Never commit real secrets.
# ============================================================

# ---- 模型配置（三选一即可）----

# 方案 A：Anthropic Claude Fable 5（推荐，长程投研推理最强）
# ANTHROPIC_API_KEY=sk-ant-...
# MODEL_PROVIDER=anthropic
# MODEL_NAME=claude-fable-5

# 方案 B：EdgeOne Makers AI Gateway（对接腾讯云一键上线）
# AI_GATEWAY_API_KEY=sk-...
# AI_GATEWAY_BASE_URL=https://ai-gateway.edgeone.link/v1
# MODEL_PROVIDER=openai_compatible
# MODEL_NAME=@makers/deepseek-v4-flash
# 生产可换成 BYOK 的 Claude / DeepSeek / 混元 等

# 方案 C：任意 OpenAI 兼容接口（DeepSeek / OpenAI / 本地 vLLM 等）
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# MODEL_PROVIDER=openai_compatible
# MODEL_NAME=deepseek-chat

# 方案 D：MiniMax M3（官方 OpenAI 兼容，适合 Agent / 长上下文）
# 文档：https://platform.minimax.io/docs/api-reference/text-openai-api
# MODEL_PROVIDER=openai_compatible
# MODEL_NAME=MiniMax-M3
# OPENAI_API_KEY=你的_MINIMAX_API_KEY
# OPENAI_BASE_URL=https://api.minimax.io/v1
# 也可用别名：MINIMAX_API_KEY=...（与 OPENAI_API_KEY 二选一）

# 默认本地开发（请改成你实际可用的）
MODEL_PROVIDER=openai_compatible
MODEL_NAME=MiniMax-M3
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.minimax.io/v1
# MINIMAX_API_KEY=

# ---- 搜索工具 ----
# Tavily：https://tavily.com （免费额度够用）
TAVILY_API_KEY=

# 可选：腾讯云联网搜索 WSA（EdgeOne 上线时用）
# WSA_API_KEY=

# ---- 运行参数 ----
# full | chokepoint_fast | risk_only | compare
RESEARCH_MODE=full
# Append English one-pager section
BILINGUAL_MEMO=false
# Write JSON+HTML alongside markdown
EXPORT_HTML_JSON=true
# 最大并行子 Agent 数
MAX_CONCURRENT_SUBAGENTS=3
# 子 Agent 最大搜索次数
MAX_SEARCHES_PER_SUBAGENT=5
# 研报输出目录
REPORTS_DIR=./reports
LOG_LEVEL=INFO
# 可选：保护 API（设置后请求需带 Header X-API-Key）
# API_ACCESS_KEY=
# 研究请求建议超时（秒，反向代理也需同步调大）
REQUEST_TIMEOUT_SECONDS=600
# Soft estimated-token budget (0=off)
MAX_TOKENS_BUDGET=0
# Optional webhook for async job completion
# WEBHOOK_URL=https://example.com/hooks/research
# API rate limit (requests per window)
API_RATE_LIMIT=120
API_RATE_WINDOW_SECONDS=60
# zh | en | bilingual
REPORT_LANGUAGE=zh
